// config.js — satoshi-note-web
// Set DEFAULT_SERVER to your satoshi-note backend URL (no trailing slash).
// Leave as empty string to require users to configure it via Settings.
window.SATOSHI_NOTE_DEFAULT_SERVER = 'https://satbase.co.za';

// Set SITE_NAME to control the header logo text.
// Use CamelCase to define word boundaries — no spaces allowed.
// Words alternate orange / white / orange / white starting with orange.
// Example: 'SatoshiNote', 'MyLightningWallet', 'BitcoinTipJar'
window.SATOSHI_NOTE_SITE_NAME = 'SatoshiNote';
